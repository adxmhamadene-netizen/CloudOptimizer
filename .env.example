# ── AWS ───────────────────────────────────────────────────────────────────────
# Leave blank to use rich mock data (good for local dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_ACCOUNT_ID=

# ── Slack ─────────────────────────────────────────────────────────────────────
# Leave blank to log alerts to stdout only
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_ALERT_CHANNEL=#cloud-alerts
SLACK_APPROVAL_CHANNEL=#cloud-approvals

# ── Behavior ──────────────────────────────────────────────────────────────────
AUTO_EXECUTE_ACTIONS=false      # set true to auto-execute approved actions
REQUIRE_SLACK_APPROVAL=true
CACHE_TTL_SECONDS=300

# ── Thresholds ────────────────────────────────────────────────────────────────
IDLE_CPU_THRESHOLD=5.0
UNDERUTILIZED_CPU_THRESHOLD=20.0
ANOMALY_THRESHOLD=2.0
